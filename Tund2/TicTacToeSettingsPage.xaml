<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tund2.TicTacToeSettingsPage"
             Title="Seaded"
             BackgroundColor="#7EB6FF"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="20"
                             Padding="25,50,25,30"
                             MaximumWidthRequest="500"
                             HorizontalOptions="Center">

            <!-- Title -->
            <Label Text="Seaded"
                   FontFamily="PoppinsBold"
                   FontSize="32"
                   TextColor="#6E00B8"
                   HorizontalTextAlignment="Center"/>

            <!-- Board Size -->
            <Border Padding="20"
                    Stroke="Transparent"
                    BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="0,3"
                            Opacity="0.12"
                            Radius="6"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="📐 Mänguvälja suurus"
                           FontSize="17"
                           FontFamily="PoppinsBold"
                           TextColor="#6E00B8"/>
                    <Label Text="Vali mänguvälja suurus"
                           FontSize="14"
                           FontFamily="PoppinsMedium"
                           TextColor="#546E7A"/>
                    <HorizontalStackLayout Spacing="12"
                                           HorizontalOptions="Center">
                        <!-- 3x3 -->
                        <Border x:Name="btn3x3"
                                BackgroundColor="#F54066"
                                WidthRequest="90"
                                HeightRequest="50"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Label Text="3 × 3"
                                   FontFamily="PoppinsBold"
                                   FontSize="16"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBoardSize3"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- 4x4 -->
                        <Border x:Name="btn4x4"
                                BackgroundColor="#F54066"
                                WidthRequest="90"
                                HeightRequest="50"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Label Text="4 × 4"
                                   FontFamily="PoppinsBold"
                                   FontSize="16"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBoardSize4"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- 5x5 -->
                        <Border x:Name="btn5x5"
                                BackgroundColor="#F54066"
                                WidthRequest="90"
                                HeightRequest="50"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Label Text="5 × 5"
                                   FontFamily="PoppinsBold"
                                   FontSize="16"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBoardSize5"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Bot Difficulty -->
            <Border Padding="20"
                    Stroke="Transparent"
                    BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="0,3"
                            Opacity="0.12"
                            Radius="6"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="🤖 Boti raskusaste"
                           FontSize="17"
                           FontFamily="PoppinsBold"
                           TextColor="#6E00B8"/>
                    <Label Text="Vali kui tugev bot on"
                           FontSize="14"
                           FontFamily="PoppinsMedium"
                           TextColor="#546E7A"/>
                    <HorizontalStackLayout Spacing="12"
                                           HorizontalOptions="Center">
                        <!-- Easy -->
                        <Border x:Name="btnEasy"
                                BackgroundColor="#F54066"
                                WidthRequest="90"
                                HeightRequest="50"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Label Text="Kerge"
                                   FontFamily="PoppinsBold"
                                   FontSize="14"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDifficultyEasy"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- Medium -->
                        <Border x:Name="btnMedium"
                                BackgroundColor="#F54066"
                                WidthRequest="90"
                                HeightRequest="50"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Label Text="Keskmine"
                                   FontFamily="PoppinsBold"
                                   FontSize="13"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDifficultyMedium"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- Hard -->
                        <Border x:Name="btnHard"
                                BackgroundColor="#F54066"
                                WidthRequest="90"
                                HeightRequest="50"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Label Text="Raske"
                                   FontFamily="PoppinsBold"
                                   FontSize="14"
                                   TextColor="White"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDifficultyHard"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
