<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tund2.RecipeBookPage"
             Title="Retsept"
             BackgroundColor="#FFF8F2">

    <ScrollView>
        <VerticalStackLayout Spacing="16"
                             Padding="16,20,16,24">
            <Label Text="Uus retsept"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#7C2D12"/>

            <Label Text="Sisesta retsepti andmed ja salvesta see oma retseptiraamatusse."
                   FontSize="14"
                   TextColor="#9A3412"/>

            <Border StrokeThickness="0"
                    BackgroundColor="White"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="18">
                    <Border StrokeThickness="0"
                            BackgroundColor="#FFF7ED"
                            Padding="14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">
                            <Label Text="Põhiinfo"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#7C2D12"/>

                            <Label Text="Retsepti nimi"
                                   TextColor="#9A3412"/>
                            <Entry x:Name="RecipeNameEntryCell"
                                   Placeholder="Nt Kreemine pasta"
                                   BackgroundColor="White"
                                   TextColor="#431407"/>

                            <Label Text="Roa tüüp"
                                   TextColor="#9A3412"/>
                            <Entry x:Name="DishTypeEntryCell"
                                   Placeholder="Nt supp, salat, magustoit"
                                   BackgroundColor="White"
                                   TextColor="#431407"/>

                            <Label Text="Lühikirjeldus"
                                   TextColor="#9A3412"/>
                            <Entry x:Name="DescriptionEntryCell"
                                   Placeholder="Kirjelda rooga lühidalt"
                                   BackgroundColor="White"
                                   TextColor="#431407"/>

                            <Label Text="Autor"
                                   TextColor="#9A3412"/>
                            <Entry x:Name="AuthorEntryCell"
                                   Placeholder="Nt Maksi"
                                   BackgroundColor="White"
                                   TextColor="#431407"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border StrokeThickness="0"
                            BackgroundColor="#FFF7ED"
                            Padding="14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="12">
                            <Label Text="Koostisosad"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#7C2D12"/>

                            <VerticalStackLayout x:Name="IngredientsContainer"
                                                 Spacing="10"/>

                            <Button Text="Lisa koostisosa"
                                    CornerRadius="12"
                                    BackgroundColor="#EA580C"
                                    TextColor="White"
                                    Clicked="OnAddIngredientClicked"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border StrokeThickness="0"
                            BackgroundColor="#FFF7ED"
                            Padding="14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="12">
                            <Label Text="Valmistamine"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#7C2D12"/>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="Valmistamise kuupäev"
                                       FontAttributes="Bold"
                                       TextColor="#7C2D12"/>
                                <DatePicker x:Name="CookingDatePicker"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="Valmistusaeg"
                                       FontAttributes="Bold"
                                       TextColor="#7C2D12"/>
                                <Label x:Name="CookingTimeValueLabel"
                                       Text="45 min"
                                       TextColor="#9A3412"/>
                                <Slider x:Name="CookingTimeSlider"
                                        Minimum="10"
                                        Maximum="180"
                                        Value="45"
                                        ValueChanged="OnCookingTimeChanged"
                                        MinimumTrackColor="#EA580C"
                                        MaximumTrackColor="#FED7AA"
                                        ThumbColor="#C2410C"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="Portsjonid"
                                       FontAttributes="Bold"
                                       TextColor="#7C2D12"/>
                                <Label x:Name="PortionsValueLabel"
                                       Text="2 portsjonit"
                                       TextColor="#9A3412"/>
                                <Stepper x:Name="PortionsStepper"
                                         Minimum="1"
                                         Maximum="12"
                                         Increment="1"
                                         Value="2"
                                         ValueChanged="OnPortionsChanged"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="Raskusaste"
                                       FontAttributes="Bold"
                                       TextColor="#7C2D12"/>
                                <Picker x:Name="DifficultyPicker"
                                        Title="Vali raskusaste">
                                    <Picker.Items>
                                        <x:String>Lihtne</x:String>
                                        <x:String>Keskmine</x:String>
                                        <x:String>Keeruline</x:String>
                                    </Picker.Items>
                                </Picker>
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <Label Text="Taimetoit"
                                       VerticalOptions="Center"
                                       TextColor="#431407"/>
                                <Switch x:Name="VegetarianSwitchCell"
                                        Grid.Column="1"/>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12">
                                <Label Text="Magus roog"
                                       VerticalOptions="Center"
                                       TextColor="#431407"/>
                                <Switch x:Name="SweetDishSwitchCell"
                                        Grid.Column="1"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Border StrokeThickness="0"
                            BackgroundColor="#FFF7ED"
                            Padding="14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">
                            <Label Text="Juhend"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#7C2D12"/>
                            <Label Text="Kirjuta lühidalt, kuidas rooga valmistada."
                                   TextColor="#9A3412"/>
                            <Editor x:Name="InstructionEditor"
                                    HeightRequest="150"
                                    AutoSize="TextChanges"
                                    Placeholder="1. Valmista koostisosad ette...&#10;2. Küpseta või sega...&#10;3. Serveeri..."
                                    BackgroundColor="White"
                                    TextColor="#431407"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border StrokeThickness="0"
                            BackgroundColor="#FFF7ED"
                            Padding="14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">
                            <Label Text="Tegevused"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#7C2D12"/>
                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="Salvesta"
                                        CornerRadius="14"
                                        BackgroundColor="#16A34A"
                                        TextColor="White"
                                        Clicked="OnSaveClicked"/>
                                <Button Grid.Column="1"
                                        Text="Puhasta"
                                        CornerRadius="14"
                                        BackgroundColor="#6B7280"
                                        TextColor="White"
                                        Clicked="OnClearClicked"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
