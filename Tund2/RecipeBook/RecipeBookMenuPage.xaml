<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tund2.RecipeBookMenuPage"
             Title="Retseptiraamat"
             BackgroundColor="#FFF8F2">

    <Grid RowDefinitions="Auto,Auto,*"
          Padding="16,20,16,16"
          RowSpacing="16">

        <VerticalStackLayout Grid.Row="0"
                             Spacing="6">
            <Label Text="Minu retseptid"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#7C2D12"/>
            <Label Text="Siin saad retsepte vaadata, lisada ja kustutada."
                   FontSize="14"
                   TextColor="#9A3412"/>
        </VerticalStackLayout>

        <Button Grid.Row="1"
                Text="Loo uus retsept"
                CornerRadius="14"
                BackgroundColor="#EA580C"
                TextColor="White"
                Clicked="OnCreateClicked"/>

        <CollectionView Grid.Row="2"
                        x:Name="RecipesCollectionView"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Border StrokeThickness="0"
                        BackgroundColor="White"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Retsepte veel ei ole."
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#7C2D12"/>
                        <Label Text="Vajuta nuppu ja loo esimene retsept."
                               TextColor="#9A3412"/>
                    </VerticalStackLayout>
                </Border>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="0"
                            BackgroundColor="White"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Name}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#7C2D12"/>
                                <Label Text="{Binding DishType}"
                                       TextColor="#9A3412"/>
                                <Label Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="#78716C"/>
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="Ava"
                                        CornerRadius="12"
                                        BackgroundColor="#16A34A"
                                        TextColor="White"
                                        Clicked="OnOpenClicked"/>
                                <Button Grid.Column="1"
                                        Text="Kustuta"
                                        CornerRadius="12"
                                        BackgroundColor="#DC2626"
                                        TextColor="White"
                                        Clicked="OnDeleteClicked"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
