<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tund2.TicTacToeWonPage"
             Title="Won"
             BackgroundColor="#7EB6FF"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout MaximumWidthRequest="428"
                             HorizontalOptions="Center"
                             Padding="30,0"
                             Spacing="0">

            <!-- Crown + Circle overlapping -->
            <Grid Margin="0,80,0,0"
                  HorizontalOptions="Center"
                  HeightRequest="267">
                <!-- Crown (drawn first = behind) -->
                <Image Source="woncrown.png"
                       WidthRequest="200"
                       HeightRequest="120"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Start"/>
                <!-- Circle (drawn second = in front) -->
                <Image x:Name="winnerImage"
                       Source="circlewonlose.png"
                       WidthRequest="202"
                       HeightRequest="202"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="End"/>
            </Grid>

            <!-- Player title -->
            <Label x:Name="winnerTitle"
                   Text="O MÄNGIJA"
                   FontFamily="PoppinsBold"
                   FontSize="36"
                   TextColor="#6E00B8"
                   HorizontalTextAlignment="Center"
                   Margin="0,20,0,0"/>

            <!-- Stars decoration image -->
            <Image Source="wonstars.png"
                   WidthRequest="340"
                   HeightRequest="140"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0"/>

            <!-- Congratulations text -->
            <Label x:Name="winMessage"
                   Text="Palju õnne"
                   FontFamily="PoppinsMedium"
                   FontSize="24"
                   TextColor="#6E00B8"
                   HorizontalTextAlignment="Center"
                   Margin="0,25,0,0"/>

            <!-- Subtitle -->
            <Label x:Name="winSubMessage"
                   Text="Sa võitsid mängu"
                   FontFamily="PoppinsMedium"
                   FontSize="16"
                   TextColor="#6E00B8"
                   HorizontalTextAlignment="Center"/>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,26,*"
                  HorizontalOptions="Fill"
                  Margin="5,55,4,30">

                <Border Grid.Column="0"
                        HeightRequest="60"
                        BackgroundColor="#F54066"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="13"/>
                    </Border.StrokeShape>
                    <Label Text="MINE KOJU"
                           FontFamily="PoppinsMedium"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMainMenu"/>
                    </Border.GestureRecognizers>
                </Border>

                <Border Grid.Column="2"
                        HeightRequest="60"
                        BackgroundColor="#F54066"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="13"/>
                    </Border.StrokeShape>
                    <Label Text="MÄNGI UUESTI"
                           FontFamily="PoppinsMedium"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPlayAgain"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
