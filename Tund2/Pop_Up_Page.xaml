<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Tund2.Pop_Up_Page"
    Title="Pop-up aknad">
    <ScrollView>
        <VerticalStackLayout Spacing="12"
                             Padding="20,30,20,30">
            <!-- Header -->
            <Label Text="Pop-up aknad"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,6"/>
            <Label Text="Akende tüübid"
                   FontSize="13"
                   TextColor="#888888"
                   Margin="4,0,0,4"/>
            <!-- 1. Lihtne teade -->
            <Button x:Name="alertButton"
                    Text="💬  Teade"
                    BackgroundColor="#4a90d9"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="60"
                    FontSize="16"
                    FontAttributes="Bold"
                    HorizontalOptions="Fill"
                    Clicked="AlertButton_Clicked"/>
            <!-- 2. Jah või ei -->
            <Button x:Name="alertYesNoButton"
                    Text="✅  Jah või ei"
                    BackgroundColor="#27ae60"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="60"
                    FontSize="16"
                    FontAttributes="Bold"
                    HorizontalOptions="Fill"
                    Clicked="AlertYesNoButton_Clicked"/>
            <!-- 3. Valikumenüü -->
            <Button x:Name="alertListButton"
                    Text="📋  Valik"
                    BackgroundColor="#8e44ad"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="60"
                    FontSize="16"
                    FontAttributes="Bold"
                    HorizontalOptions="Fill"
                    Clicked="AlertListButton_Clicked"/>
            <!-- 4. Sisestusaken -->
            <Button x:Name="alertQuestButton"
                    Text="⌨️  Küsimus"
                    BackgroundColor="#e67e22"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="60"
                    FontSize="16"
                    FontAttributes="Bold"
                    HorizontalOptions="Fill"
                    Clicked="AlertQuestButton_Clicked"/>
            <!-- Divider -->
            <BoxView HeightRequest="1"
                     Color="#e0e0e0"
                     Margin="0,16,0,8"/>
            <Label Text="Arendaja tööriistad"
                   FontSize="13"
                   TextColor="#888888"
                   Margin="4,0,0,4"/>
            <!-- Nulli seaded -->
            <Button x:Name="nulliNupp"
                    Text="🗑️  Nulli seaded"
                    BackgroundColor="#e74c3c"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="52"
                    FontSize="15"
                    HorizontalOptions="Fill"
                    Clicked="NulliNupp_Clicked"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
