<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Tund2.TicTacToePage"
             Title="Mäng"
             BackgroundColor="#7EB6FF"
             Shell.NavBarIsVisible="False">

    <Grid MaximumWidthRequest="428"
          HorizontalOptions="Center"
          VerticalOptions="Center"
          Padding="27,0">

        <!-- Player cards -->
        <Grid ColumnDefinitions="*,40,*"
              HorizontalOptions="Fill"
              VerticalOptions="Start"
              Margin="0,0,0,0">

            <!-- Player X card -->
            <Border Grid.Column="0"
                    HeightRequest="150"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="26"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">
                    <Border BackgroundColor="#00AAFF"
                            WidthRequest="87"
                            HeightRequest="41"
                            StrokeThickness="0"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Image Source="crosspurple.png"
                               WidthRequest="30"
                               HeightRequest="30"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Player 1"
                           FontFamily="PoppinsBold"
                           FontSize="14"
                           TextColor="#FF8000"
                           HorizontalTextAlignment="Center"/>
                    <HorizontalStackLayout Spacing="8"
                                           HorizontalOptions="Center">
                        <Image Source="crown.png"
                               WidthRequest="18"
                               HeightRequest="18"
                               VerticalOptions="Center"/>
                        <Label x:Name="xScoreLabel"
                               Text="Võit: 0"
                               FontFamily="PoppinsMedium"
                               FontSize="14"
                               TextColor="#FF8000"
                               VerticalTextAlignment="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Player O card -->
            <Border Grid.Column="2"
                    HeightRequest="150"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="26"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">
                    <Border BackgroundColor="#00AAFF"
                            WidthRequest="87"
                            HeightRequest="41"
                            StrokeThickness="0"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Image Source="circleorange.png"
                               WidthRequest="30"
                               HeightRequest="30"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Player 2"
                           FontFamily="PoppinsBold"
                           FontSize="14"
                           TextColor="#FF8000"
                           HorizontalTextAlignment="Center"/>
                    <HorizontalStackLayout Spacing="8"
                                           HorizontalOptions="Center">
                        <Image Source="crown.png"
                               WidthRequest="18"
                               HeightRequest="18"
                               VerticalOptions="Center"/>
                        <Label x:Name="oScoreLabel"
                               Text="Võit: 0"
                               FontFamily="PoppinsMedium"
                               FontSize="14"
                               TextColor="#FF8000"
                               VerticalTextAlignment="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Status label -->
        <Label x:Name="statusLabel"
               Text="Mängija X käik"
               FontFamily="PoppinsMedium"
               FontSize="20"
               TextColor="Black"
               HorizontalTextAlignment="Center"
               VerticalOptions="Start"
               Margin="0,215,0,0"
               Opacity="0.75"/>

        <!-- Game board -->
        <Border x:Name="boardBorder"
                Padding="0"
                BackgroundColor="Black"
                StrokeThickness="0"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                Margin="0,320,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="35"/>
            </Border.StrokeShape>
            <Grid x:Name="boardGrid"
                  RowSpacing="2"
                  ColumnSpacing="2"
                  HorizontalOptions="Center"
                  VerticalOptions="Center"/>
        </Border>


    </Grid>

</ContentPage>
