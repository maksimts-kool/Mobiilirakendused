<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="Tund2.StartPage"
             Title="Minu Projektid"
             BackgroundColor="#F5F7FB">
    <ContentPage.Resources>
        <Style x:Key="SectionTitleStyle"
               TargetType="Label">
            <Setter Property="FontFamily"
                    Value="PoppinsBold"/>
            <Setter Property="FontSize"
                    Value="18"/>
            <Setter Property="TextColor"
                    Value="#344054"/>
            <Setter Property="Margin"
                    Value="0,6,0,-8"/>
        </Style>

        <Style x:Key="GalleryCardStyle"
               TargetType="Border">
            <Setter Property="HeightRequest"
                    Value="{OnIdiom Phone=194, Default=208}"/>
            <Setter Property="HorizontalOptions"
                    Value="Fill"/>
            <Setter Property="Padding"
                    Value="18"/>
            <Setter Property="Scale"
                    Value="0.94"/>
            <Setter Property="Opacity"
                    Value="0.72"/>
            <Setter Property="StrokeThickness"
                    Value="1"/>
            <Setter Property="Stroke"
                    Value="#E3E8F1"/>
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <shapes:RoundRectangle CornerRadius="18"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Brush="Black"
                            Offset="0,4"
                            Opacity="0.12"
                            Radius="12"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistoryRowStyle"
               TargetType="Border">
            <Setter Property="Padding"
                    Value="14"/>
            <Setter Property="StrokeThickness"
                    Value="1"/>
            <Setter Property="Stroke"
                    Value="#E5EAF2"/>
            <Setter Property="BackgroundColor"
                    Value="White"/>
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <shapes:RoundRectangle CornerRadius="14"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Brush="Black"
                            Offset="0,2"
                            Opacity="0.08"
                            Radius="8"/>
                </Setter.Value>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,28"
                             Spacing="22">
            <VerticalStackLayout x:Name="HeaderLayout"
                                 Margin="0,6,0,0"
                                 Spacing="6">
                <Label Text="Vali rakendus"
                       FontFamily="PoppinsBold"
                       FontSize="30"
                       TextColor="#18212F"/>
                <Label Text="Uuemad tööd on ees, varasemad leiad ajaloost."
                       FontFamily="OpenSansRegular"
                       FontSize="15"
                       TextColor="#667085"/>
            </VerticalStackLayout>

            <Label x:Name="FeaturedTitle"
                   Text="Uued lehed"
                   Style="{StaticResource SectionTitleStyle}"/>

            <CarouselView x:Name="FeaturedCarousel"
                          HeightRequest="{OnIdiom Phone=234, Default=248}"
                          HorizontalOptions="Fill"
                          IsBounceEnabled="True"
                          IsSwipeEnabled="True"
                          Loop="True"
                          PeekAreaInsets="{OnIdiom Phone=54, Default=132}"
                          Position="0"
                          PositionChanged="OnFeaturedPositionChanged">
                <CarouselView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal"
                                       SnapPointsAlignment="Center"
                                       SnapPointsType="MandatorySingle"/>
                </CarouselView.ItemsLayout>
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <ContentView Padding="5,10,5,14"
                                     HorizontalOptions="Fill"
                                     VerticalOptions="Center">
                            <Border Style="{StaticResource GalleryCardStyle}"
                                    Loaded="OnFeaturedCardLoaded"
                                    Unloaded="OnFeaturedCardUnloaded">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0"
                                                         EndPoint="1,1">
                                        <GradientStop Color="{Binding BackgroundColor}"
                                                      Offset="0"/>
                                        <GradientStop Color="White"
                                                      Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMenuItemTapped"
                                                          CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            WidthRequest="52"
                                            HeightRequest="52"
                                            HorizontalOptions="Center"
                                            StrokeThickness="0"
                                            BackgroundColor="{Binding AccentColor}">
                                        <Border.StrokeShape>
                                            <shapes:RoundRectangle CornerRadius="26"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Initials}"
                                               FontFamily="PoppinsBold"
                                               FontSize="17"
                                               TextColor="White"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center"/>
                                    </Border>

                                    <Label Grid.Row="1"
                                           Text="{Binding Name}"
                                           FontFamily="PoppinsBold"
                                           FontSize="{OnIdiom Phone=17, Default=19}"
                                           Margin="0,6,0,0"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           LineHeight="1.05"
                                           TextColor="#18212F"/>

                                    <Label Grid.Row="2"
                                           Text="{Binding Description}"
                                           FontFamily="OpenSansRegular"
                                           FontSize="{OnIdiom Phone=12, Default=13}"
                                           MaxLines="3"
                                           LineBreakMode="TailTruncation"
                                           LineHeight="1.18"
                                           VerticalOptions="Start"
                                           TextColor="#5D6675"/>
                                </Grid>
                            </Border>
                        </ContentView>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <Label x:Name="HistoryTitle"
                   Text="Ajalugu"
                   Style="{StaticResource SectionTitleStyle}"/>

            <VerticalStackLayout x:Name="HistoryList"
                                 Spacing="12">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource HistoryRowStyle}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMenuItemTapped"
                                                      CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        WidthRequest="42"
                                        HeightRequest="42"
                                        StrokeThickness="0"
                                        BackgroundColor="{Binding AccentColor}">
                                    <Border.StrokeShape>
                                        <shapes:RoundRectangle CornerRadius="21"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Initials}"
                                           FontFamily="PoppinsBold"
                                           FontSize="14"
                                           TextColor="White"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontFamily="PoppinsMedium"
                                           FontSize="16"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="#243044"/>
                                    <Label Text="{Binding Description}"
                                           FontFamily="OpenSansRegular"
                                           FontSize="13"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"
                                           TextColor="#697386"/>
                                </VerticalStackLayout>

                                <Label Grid.Column="2"
                                       Text=">"
                                       FontFamily="PoppinsMedium"
                                       FontSize="20"
                                       TextColor="#98A2B3"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
