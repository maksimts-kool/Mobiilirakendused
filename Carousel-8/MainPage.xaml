<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Carousel_8.MainPage"
             BackgroundColor="#C8FFCA"
             Shell.NavBarIsVisible="False">

        <ContentPage.Resources>
                <LinearGradientBrush x:Key="LeftPreviewMask"
                                     StartPoint="0,0.5"
                                     EndPoint="1,0.5">
                        <GradientStop Color="#08FFFFFF"
                                      Offset="0"/>
                        <GradientStop Color="#8CFFFFFF"
                                      Offset="0.62"/>
                        <GradientStop Color="#E8FFFFFF"
                                      Offset="1"/>
                </LinearGradientBrush>

                <LinearGradientBrush x:Key="RightPreviewMask"
                                     StartPoint="1,0.5"
                                     EndPoint="0,0.5">
                        <GradientStop Color="#08FFFFFF"
                                      Offset="0"/>
                        <GradientStop Color="#8CFFFFFF"
                                      Offset="0.62"/>
                        <GradientStop Color="#E8FFFFFF"
                                      Offset="1"/>
                </LinearGradientBrush>

                <Style x:Key="HeroTitleStyle"
                       TargetType="Label">
                        <Setter Property="FontFamily"
                                Value="PoppinsBold"/>
                        <Setter Property="FontSize"
                                Value="{OnIdiom Phone=28, Tablet=30, Desktop=32}"/>
                        <Setter Property="LineHeight"
                                Value="1.1"/>
                        <Setter Property="MaxLines"
                                Value="2"/>
                        <Setter Property="TextColor"
                                Value="Black"/>
                </Style>

                <Style x:Key="HeroSubtitleStyle"
                       TargetType="Label">
                        <Setter Property="FontFamily"
                                Value="PoppinsLight"/>
                        <Setter Property="FontSize"
                                Value="{OnIdiom Phone=16, Tablet=17, Desktop=18}"/>
                        <Setter Property="LineHeight"
                                Value="1.35"/>
                        <Setter Property="MaxLines"
                                Value="3"/>
                        <Setter Property="TextColor"
                                Value="#243728"/>
                </Style>

                <Style x:Key="LanguageLabelStyle"
                       TargetType="Label">
                        <Setter Property="FontFamily"
                                Value="PoppinsRegular"/>
                        <Setter Property="FontSize"
                                Value="{OnIdiom Phone=12, Tablet=13, Desktop=13}"/>
                        <Setter Property="TextColor"
                                Value="#99000000"/>
                </Style>

                <Style x:Key="LanguageButtonStyle"
                       TargetType="Button">
                        <Setter Property="FontFamily"
                                Value="PoppinsMedium"/>
                        <Setter Property="FontSize"
                                Value="{OnIdiom Phone=14, Tablet=14, Desktop=15}"/>
                        <Setter Property="BackgroundColor"
                                Value="#EDFFE3"/>
                        <Setter Property="BorderColor"
                                Value="#6697FFAA"/>
                        <Setter Property="BorderWidth"
                                Value="1.5"/>
                        <Setter Property="CornerRadius"
                                Value="100"/>
                        <Setter Property="MinimumHeightRequest"
                                Value="{OnIdiom Phone=34, Tablet=36, Desktop=38}"/>
                        <Setter Property="Padding"
                                Value="{OnIdiom Phone='20,8', Tablet='22,9', Desktop='24,10'}"/>
                        <Setter Property="TextColor"
                                Value="#087D16"/>
                </Style>

                <Style x:Key="InstructionTextStyle"
                       TargetType="Label">
                        <Setter Property="FontFamily"
                                Value="PoppinsRegular"/>
                        <Setter Property="FontSize"
                                Value="{OnIdiom Phone=14, Tablet=15, Desktop=15}"/>
                        <Setter Property="LineHeight"
                                Value="1.3"/>
                        <Setter Property="TextColor"
                                Value="#27472F"/>
                </Style>

                <Style x:Key="CardTitleStyle"
                       TargetType="Label">
                        <Setter Property="FontFamily"
                                Value="PoppinsMedium"/>
                        <Setter Property="FontSize"
                                Value="{OnIdiom Phone=24, Tablet=25, Desktop=26}"/>
                        <Setter Property="LineHeight"
                                Value="1.12"/>
                        <Setter Property="MaxLines"
                                Value="2"/>
                        <Setter Property="TextColor"
                                Value="Black"/>
                </Style>

                <Style x:Key="CardDescriptionStyle"
                       TargetType="Label">
                        <Setter Property="FontFamily"
                                Value="PoppinsLight"/>
                        <Setter Property="FontSize"
                                Value="{OnIdiom Phone=16, Tablet=17, Desktop=17}"/>
                        <Setter Property="LineHeight"
                                Value="1.34"/>
                        <Setter Property="MaxLines"
                                Value="3"/>
                        <Setter Property="TextColor"
                                Value="#2F4737"/>
                </Style>
        </ContentPage.Resources>

        <Grid Padding="{OnIdiom Phone='0,35,0,24', Tablet='0,42,0,30', Desktop='0,48,0,36'}"
              RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="{OnIdiom Phone=20, Tablet=22, Desktop=26}">

                <Grid x:Name="HeroSection"
                      Grid.Row="0"
                      Margin="{OnIdiom Phone='20,4,20,4', Tablet='44,4,44,4', Desktop='80,6,80,6'}"
                      Padding="{OnIdiom Phone='6', Tablet='7', Desktop='8'}">
                        <Border Padding="{OnIdiom Phone='26,28,26,25', Tablet='30,32,30,28', Desktop='34,34,34,30'}"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 30">
                                <Border.Shadow>
                                        <Shadow Brush="Black"
                                                Offset="0,0"
                                                Radius="12"
                                                Opacity="0.32"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="{OnIdiom Phone=16, Tablet=18, Desktop=20}">
                                        <Label Style="{StaticResource HeroTitleStyle}"
                                               Text="{Binding HeroTitleText}"/>

                                        <Label Style="{StaticResource HeroSubtitleStyle}"
                                               Text="{Binding HeroSubtitleText}"/>

                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="{OnIdiom Phone=12, Tablet=14, Desktop=16}"
                                              RowDefinitions="Auto">
                                                <Label Grid.Column="0"
                                                       Style="{StaticResource LanguageLabelStyle}"
                                                       VerticalOptions="Center"
                                                       Text="{Binding LanguageLabelText}"/>

                                                <HorizontalStackLayout Grid.Column="1"
                                                                       HorizontalOptions="End"
                                                                       Spacing="{OnIdiom Phone=10, Tablet=12, Desktop=12}">
                                                        <Button Clicked="OnEnglishClicked"
                                                                Style="{StaticResource LanguageButtonStyle}"
                                                                Text="{Binding LanguageEnglishText}">
                                                                <Button.Triggers>
                                                                        <DataTrigger TargetType="Button"
                                                                                     Binding="{Binding IsEnglishSelected}"
                                                                                     Value="True">
                                                                                <Setter Property="BackgroundColor"
                                                                                        Value="#087D16"/>
                                                                                <Setter Property="BorderColor"
                                                                                        Value="#C8FFCA"/>
                                                                                <Setter Property="TextColor"
                                                                                        Value="White"/>
                                                                        </DataTrigger>
                                                                </Button.Triggers>
                                                        </Button>

                                                        <Button Clicked="OnEstonianClicked"
                                                                Style="{StaticResource LanguageButtonStyle}"
                                                                Text="{Binding LanguageEstonianText}">
                                                                <Button.Triggers>
                                                                        <DataTrigger TargetType="Button"
                                                                                     Binding="{Binding IsEstonianSelected}"
                                                                                     Value="True">
                                                                                <Setter Property="BackgroundColor"
                                                                                        Value="#087D16"/>
                                                                                <Setter Property="BorderColor"
                                                                                        Value="#C8FFCA"/>
                                                                                <Setter Property="TextColor"
                                                                                        Value="White"/>
                                                                        </DataTrigger>
                                                                </Button.Triggers>
                                                        </Button>
                                                </HorizontalStackLayout>
                                        </Grid>
                                </VerticalStackLayout>
                        </Border>
                </Grid>

                <Label Grid.Row="1"
                       Margin="{OnIdiom Phone='45,0,45,0', Tablet='44,0,44,0', Desktop='80,0,80,0'}"
                       HorizontalOptions="Fill"
                       HorizontalTextAlignment="Center"
                       Style="{StaticResource InstructionTextStyle}"
                       Text="{Binding SectionLabelText}"/>

                <Grid x:Name="CarouselSection"
                      Grid.Row="2"
                      HeightRequest="{OnIdiom Phone=528, Tablet=570, Desktop=614}">

                        <Border x:Name="LeftPreviewCard"
                                BackgroundColor="White"
                                HeightRequest="{OnIdiom Phone=494, Tablet=528, Desktop=568}"
                                HorizontalOptions="Start"
                                InputTransparent="True"
                                IsVisible="{Binding HasPreviewCards}"
                                Margin="{OnIdiom Phone='-326,18,0,0', Tablet='-352,22,0,0', Desktop='-400,28,0,0'}"
                                Opacity="0.78"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 30"
                                VerticalOptions="Start"
                                WidthRequest="{OnIdiom Phone=345, Tablet=372, Desktop=408}">
                                <Border.Shadow>
                                        <Shadow Brush="Black"
                                                Offset="0,0"
                                                Radius="6"
                                                Opacity="0.3"/>
                                </Border.Shadow>

                                <Grid BindingContext="{Binding PreviousCard}"
                                      RowDefinitions="{OnIdiom Phone='304,190', Tablet='326,202', Desktop='352,216'}">
                                        <Border BackgroundColor="#EDFCEB"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 30,30,0,0">
                                                <Image Aspect="AspectFill"
                                                       HorizontalOptions="Fill"
                                                       Scale="1.04"
                                                       Source="{Binding ImageSource}"
                                                       VerticalOptions="Fill"/>
                                        </Border>

                                        <Grid Grid.Row="1"
                                              Padding="{OnIdiom Phone='24,22,24,24', Tablet='28,24,28,28', Desktop='30,26,30,30'}"
                                              RowDefinitions="{OnIdiom Phone='54,80', Tablet='58,84', Desktop='60,92'}"
                                              RowSpacing="{OnIdiom Phone=10, Tablet=12, Desktop=12}">
                                                <Grid>
                                                        <Label AutomationId="CardTitle"
                                                               Loaded="OnCardTextLoaded"
                                                               SizeChanged="OnCardTextSizeChanged"
                                                               Style="{StaticResource CardTitleStyle}"
                                                               Text="{Binding Title}"
                                                               Unloaded="OnCardTextUnloaded"
                                                               VerticalTextAlignment="Start"/>
                                                </Grid>

                                                <Grid Grid.Row="1">
                                                        <Label AutomationId="CardDescription"
                                                               Loaded="OnCardTextLoaded"
                                                               SizeChanged="OnCardTextSizeChanged"
                                                               Style="{StaticResource CardDescriptionStyle}"
                                                               Text="{Binding Description}"
                                                               Unloaded="OnCardTextUnloaded"
                                                               VerticalTextAlignment="Start"/>
                                                </Grid>
                                        </Grid>

                                        <Border x:Name="LeftPreviewMaskLayer"
                                                Grid.RowSpan="2"
                                                Background="{StaticResource LeftPreviewMask}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 30"/>
                                </Grid>
                        </Border>

                        <Border x:Name="RightPreviewCard"
                                BackgroundColor="White"
                                HeightRequest="{OnIdiom Phone=494, Tablet=528, Desktop=568}"
                                HorizontalOptions="End"
                                InputTransparent="True"
                                IsVisible="{Binding HasPreviewCards}"
                                Margin="{OnIdiom Phone='0,18,-326,0', Tablet='0,22,-352,0', Desktop='0,28,-400,0'}"
                                Opacity="0.78"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 30"
                                VerticalOptions="Start"
                                WidthRequest="{OnIdiom Phone=345, Tablet=372, Desktop=408}">
                                <Border.Shadow>
                                        <Shadow Brush="Black"
                                                Offset="0,0"
                                                Radius="6"
                                                Opacity="0.3"/>
                                </Border.Shadow>

                                <Grid BindingContext="{Binding NextCard}"
                                      RowDefinitions="{OnIdiom Phone='304,190', Tablet='326,202', Desktop='352,216'}">
                                        <Border BackgroundColor="#EDFCEB"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 30,30,0,0">
                                                <Image Aspect="AspectFill"
                                                       HorizontalOptions="Fill"
                                                       Scale="1.04"
                                                       Source="{Binding ImageSource}"
                                                       VerticalOptions="Fill"/>
                                        </Border>

                                        <Grid Grid.Row="1"
                                              Padding="{OnIdiom Phone='24,22,24,24', Tablet='28,24,28,28', Desktop='30,26,30,30'}"
                                              RowDefinitions="{OnIdiom Phone='54,80', Tablet='58,84', Desktop='60,92'}"
                                              RowSpacing="{OnIdiom Phone=10, Tablet=12, Desktop=12}">
                                                <Grid>
                                                        <Label AutomationId="CardTitle"
                                                               Loaded="OnCardTextLoaded"
                                                               SizeChanged="OnCardTextSizeChanged"
                                                               Style="{StaticResource CardTitleStyle}"
                                                               Text="{Binding Title}"
                                                               Unloaded="OnCardTextUnloaded"
                                                               VerticalTextAlignment="Start"/>
                                                </Grid>

                                                <Grid Grid.Row="1">
                                                        <Label AutomationId="CardDescription"
                                                               Loaded="OnCardTextLoaded"
                                                               SizeChanged="OnCardTextSizeChanged"
                                                               Style="{StaticResource CardDescriptionStyle}"
                                                               Text="{Binding Description}"
                                                               Unloaded="OnCardTextUnloaded"
                                                               VerticalTextAlignment="Start"/>
                                                </Grid>
                                        </Grid>

                                        <Border x:Name="RightPreviewMaskLayer"
                                                Grid.RowSpan="2"
                                                Background="{StaticResource RightPreviewMask}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 30"/>
                                </Grid>
                        </Border>

                        <CarouselView x:Name="MainCarousel"
                                      HeightRequest="{OnIdiom Phone=528, Tablet=570, Desktop=614}"
                                      HorizontalOptions="Fill"
                                      HorizontalScrollBarVisibility="Never"
                                      IndicatorView="{x:Reference CarouselIndicator}"
                                      ItemsSource="{Binding Cards}"
                                      PeekAreaInsets="0"
                                      Scrolled="OnCarouselScrolled"
                                      PositionChanged="OnCarouselPositionChanged"
                                      VerticalOptions="Start"
                                      VerticalScrollBarVisibility="Never">
                                <CarouselView.ItemTemplate>
                                        <DataTemplate>
                                                <Grid Padding="{OnIdiom Phone='0,18,0,0', Tablet='0,22,0,0', Desktop='0,28,0,0'}">
                                                        <Border BackgroundColor="White"
                                                                HeightRequest="{OnIdiom Phone=494, Tablet=528, Desktop=568}"
                                                                HorizontalOptions="Center"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 30"
                                                                VerticalOptions="Start"
                                                                WidthRequest="{OnIdiom Phone=345, Tablet=372, Desktop=408}">
                                                                <Border.Shadow>
                                                                        <Shadow Brush="Black"
                                                                                Offset="0,0"
                                                                                Radius="6"
                                                                                Opacity="0.3"/>
                                                                </Border.Shadow>

                                                                <Border.GestureRecognizers>
                                                                        <TapGestureRecognizer CommandParameter="{Binding .}"
                                                                                              Tapped="OnCardTapped"/>
                                                                </Border.GestureRecognizers>

                                                                <Grid RowDefinitions="{OnIdiom Phone='304,190', Tablet='326,202', Desktop='352,216'}">
                                                                        <Border BackgroundColor="#EDFCEB"
                                                                                StrokeThickness="0"
                                                                                StrokeShape="RoundRectangle 30,30,0,0">
                                                                                <Image Aspect="AspectFill"
                                                                                       HorizontalOptions="Fill"
                                                                                       Scale="1.04"
                                                                                       Source="{Binding ImageSource}"
                                                                                       VerticalOptions="Fill"/>
                                                                        </Border>

                                                                        <Grid Grid.Row="1"
                                                                              Padding="{OnIdiom Phone='24,22,24,24', Tablet='28,24,28,28', Desktop='30,26,30,30'}"
                                                                              RowDefinitions="{OnIdiom Phone='54,80', Tablet='58,84', Desktop='60,92'}"
                                                                              RowSpacing="{OnIdiom Phone=10, Tablet=12, Desktop=12}">
                                                                                <Grid>
                                                                                        <Label AutomationId="CardTitle"
                                                                                               Loaded="OnCardTextLoaded"
                                                                                               SizeChanged="OnCardTextSizeChanged"
                                                                                               Style="{StaticResource CardTitleStyle}"
                                                                                               Text="{Binding Title}"
                                                                                               Unloaded="OnCardTextUnloaded"
                                                                                               VerticalTextAlignment="Start"/>
                                                                                </Grid>

                                                                                <Grid Grid.Row="1">
                                                                                        <Label AutomationId="CardDescription"
                                                                                               Loaded="OnCardTextLoaded"
                                                                                               SizeChanged="OnCardTextSizeChanged"
                                                                                               Style="{StaticResource CardDescriptionStyle}"
                                                                                               Text="{Binding Description}"
                                                                                               Unloaded="OnCardTextUnloaded"
                                                                                               VerticalTextAlignment="Start"/>
                                                                                </Grid>
                                                                        </Grid>
                                                                </Grid>
                                                        </Border>
                                                </Grid>
                                        </DataTemplate>
                                </CarouselView.ItemTemplate>
                        </CarouselView>
                </Grid>

                <IndicatorView x:Name="CarouselIndicator"
                               Grid.Row="3"
                               HorizontalOptions="Center"
                               IndicatorColor="#84B88B"
                               Margin="{OnIdiom Phone='0,8,0,0', Tablet='0,10,0,0', Desktop='0,12,0,0'}"
                               SelectedIndicatorColor="#0B4F1A"/>
        </Grid>

</ContentPage>
